# Telegram Bot 설정
# @BotFather에서 봇 생성 후 토큰 입력
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Telegram Chat ID (봇에 /start 보낸 후 확인)
TELEGRAM_CHAT_ID=your_chat_id_here

# 서버 포트
PORT=3847

# 승인 대기 타임아웃 (초)
APPROVAL_TIMEOUT=300

# 자동 승인 활성화 (true/false)
AUTO_APPROVE_ENABLED=false

# 외부 접속용 (ngrok 등 사용 시)
EXTERNAL_URL=

# API 키 인증 (설정 시 모든 API 요청에 x-api-key 헤더 필요, 미설정 시 인증 없음)
API_KEY=
