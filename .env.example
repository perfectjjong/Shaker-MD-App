# Telegram Bot 설정
# @BotFather에서 봇 생성 후 토큰 입력
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Telegram Chat ID (봇에 /start 보낸 후 확인)
TELEGRAM_CHAT_ID=your_chat_id_here

# 서버 포트
PORT=3847

# 승인 대기 타임아웃 (초)
APPROVAL_TIMEOUT=300

# 자동 승인 활성화 (true/false)
AUTO_APPROVE_ENABLED=false

# 외부 접속 터널 (같은 Wi-Fi 없이도 모바일 접속 가능)
# true로 설정하면 서버 시작 시 자동으로 외부 URL 생성
TUNNEL_ENABLED=false
# 고정 서브도메인 (선택, 미설정 시 랜덤 URL)
# TUNNEL_SUBDOMAIN=my-approver

# 직접 외부 URL 지정 (ngrok 등 사용 시, TUNNEL_ENABLED 대신 사용)
EXTERNAL_URL=

# API 키 인증 (설정 시 모든 API 요청에 x-api-key 헤더 필요, 미설정 시 인증 없음)
# 웹 대시보드 접속 시 URL에 ?api_key=YOUR_KEY 추가 필요
API_KEY=

# VAPID 키 (Web Push 알림용, npx web-push generate-vapid-keys 로 생성)
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_EMAIL=mailto:your-real-email@example.com
