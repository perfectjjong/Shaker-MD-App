# Telegram Bot 설정
# @BotFather에서 봇 생성 후 토큰 입력
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Telegram Chat ID (봇에 /start 보낸 후 확인)
TELEGRAM_CHAT_ID=your_chat_id_here

# 서버 포트
PORT=3847

# 승인 대기 타임아웃 (초)
APPROVAL_TIMEOUT=300

# 자동 승인 활성화 (true/false)
AUTO_APPROVE_ENABLED=false

# 외부 접속용 (ngrok 등 사용 시)
EXTERNAL_URL=

# API 키 인증 (설정 시 모든 API 요청에 x-api-key 헤더 필요, 미설정 시 인증 없음)
API_KEY=

# ─── 에이전트 간 통신 (Task 시스템) ─────────────────────────

# 자동 승인 위험도 임계값: 'none'|'low'|'medium' (기본: low)
# none   = 위험도 기반 자동승인 끔 (이력 기반만 동작)
# low    = 읽기 전용/안전 명령어만 자동 승인
# medium = low + 파일 수정/일반 명령어도 자동 승인
TASK_AUTO_APPROVE_RISK=low

# 승인 이력 보관 기간 (일, 기본: 30) - 이 기간 내 승인한 작업은 재승인 없이 자동 승인
TASK_APPROVAL_HISTORY_TTL=30

# 작업 승인 타임아웃 (초, 기본 600)
TASK_APPROVAL_TIMEOUT=600

# 작업 실행 타임아웃 (초, 기본 1800)
TASK_EXECUTION_TIMEOUT=1800

# Executor 공유 시크릿 (미설정 시 인증 생략)
EXECUTOR_SECRET=

# 결과 최대 크기 (바이트, 기본 1MB)
MAX_RESULT_SIZE=1048576

# ─── Executor 클라이언트 설정 (executor-client.js) ──────────

# Executor ID (기본: executor-<PID>)
EXECUTOR_ID=executor-sonolbot

# Executor가 연결할 서버 WebSocket URL
EXECUTOR_SERVER_URL=ws://localhost:3847/ws/executor

# Executor가 사용할 HTTP API URL
EXECUTOR_API_URL=http://localhost:3847

# 허용 디렉토리 (콤마 구분, 미설정 시 제한 없음)
EXECUTOR_ALLOWED_DIRS=

# 최대 동시 실행 작업 수 (기본 1)
EXECUTOR_MAX_CONCURRENT=1

# HTTP polling 간격 (ms, WS 연결 실패 시 사용, 기본 5000)
POLL_INTERVAL_MS=5000

# 작업 완료/실패 시 POST 알림을 보낼 URL (소놀봇 webhook, 선택사항)
# 예: http://localhost:8765/executor-webhook
# Payload: { taskId, title, type, status, exitCode, stdout, stderr, error, durationMs, executorId }
EXECUTOR_WEBHOOK_URL=
