<!DOCTYPE html>
<html lang="en"><head>
<meta charset="UTF-8"/><meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>Tamkeen Sell-out Weekly Dashboard</title>
<script src="https://cdn.tailwindcss.com"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2"></script>
<script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
<script>
tailwind.config={theme:{extend:{fontFamily:{sans:['Inter','system-ui','sans-serif']},colors:{navy:{50:'#E8F4FD',100:'#D1E9FB',200:'#A3D3F7',500:'#2E75B6',700:'#1E3A5F',800:'#1F4E79',900:'#0F2A42'}}}}}
</script>
<style>
body{background:#0f172a;color:#e2e8f0;font-family:'Inter',sans-serif}
header{background:linear-gradient(135deg,#1e293b,#334155);border-bottom:2px solid #10b981}
.tab-btn{padding:8px 20px;border-radius:8px 8px 0 0;font-size:13px;font-weight:600;cursor:pointer;transition:all .2s;border:1px solid transparent}
.tab-btn.active{background:#1e293b;color:#34d399;border-color:#334155;border-bottom-color:#1e293b}
.tab-btn:not(.active){background:#0f172a;color:#94a3b8}
.tab-btn:hover:not(.active){color:#e2e8f0;background:#1e293b50}
.card{background:#1e293b;border-radius:12px;padding:20px;border:1px solid #334155}
.kpi-card{background:#1e293b;border-radius:12px;padding:16px 20px;border-left:4px solid #10b981}
.kpi-val{font-size:28px;font-weight:700;color:#f1f5f9}
.kpi-label{font-size:11px;color:#94a3b8;text-transform:uppercase;letter-spacing:.5px}
.kpi-change{font-size:12px;font-weight:600}
.up{color:#f87171}.dn{color:#4ade80}
.tbl-wrap{overflow-x:auto}
.tbl-wrap table{width:100%;border-collapse:collapse;font-size:12px}
.tbl-wrap th{background:#334155;color:#fff;padding:8px 12px;text-align:left;position:sticky;top:0;z-index:2;white-space:nowrap;cursor:pointer;user-select:none;font-weight:600;font-size:11px}
.tbl-wrap th:hover{background:#475569}
.tbl-wrap td{padding:6px 12px;border-bottom:1px solid #334155;white-space:nowrap;color:#e2e8f0}
.tbl-wrap tr:nth-child(even) td{background:#1e293b}
.tbl-wrap tr:nth-child(odd) td{background:#0f172a}
.tbl-wrap tr:hover td{background:#334155}
.ms-wrap{position:relative;display:inline-block}
.ms-btn{display:flex;align-items:center;gap:4px;padding:4px 12px;border:1px solid #64748b;border-radius:6px;background:#0f172a;color:#f1f5f9;font-size:12px;cursor:pointer;font-weight:500}
.ms-btn:hover{border-color:#34d399;background:#1e293b}
.ms-menu{display:none;position:absolute;top:100%;left:0;z-index:50;min-width:180px;max-height:280px;background:#1e293b;border:1px solid #475569;border-radius:8px;box-shadow:0 8px 25px rgba(0,0,0,.4);margin-top:2px;overflow:hidden}
.ms-list{max-height:220px;overflow-y:auto}
.ms-menu.open{display:block}
.ms-menu label{display:flex;align-items:center;gap:6px;padding:4px 10px;cursor:pointer;font-size:11px;color:#e2e8f0}
.ms-menu label:hover{background:#334155}
.ms-menu .ms-actions{display:flex;gap:8px;padding:6px 10px;border-bottom:1px solid #334155;font-size:10px}
.ms-menu .ms-actions button{color:#34d399;font-weight:600;cursor:pointer;background:none;border:none}
.ms-menu .ms-actions button.ms-none{color:#f87171}
.progress-bar{height:8px;border-radius:4px;background:#334155;overflow:hidden}
.progress-fill{height:100%;border-radius:4px;background:linear-gradient(90deg,#10b981,#34d399)}
.cat-badge{display:inline-block;padding:2px 8px;border-radius:4px;font-size:10px;font-weight:600}
.cat-split{background:#1e3a5f;color:#60a5fa}
.cat-window{background:#422006;color:#fbbf24}
.cat-floor{background:#14532d;color:#4ade80}
.cat-concealed{background:#3b1f4e;color:#c084fc}
.cat-cassette{background:#1e3a4f;color:#67e8f9}
@media(max-width:640px){
  .kpi-val{font-size:20px}
  .tab-btn{padding:6px 12px;font-size:11px}
  .card{padding:12px}
  .tbl-wrap td,.tbl-wrap th{padding:4px 6px;font-size:10px}
  canvas{max-height:250px!important}
}
</style>
</head>
<body>
<header class="py-4">
<div class="max-w-[1600px] mx-auto px-6 flex justify-between items-center">
  <div>
    <h1 class="text-2xl font-bold text-white">Tamkeen Sell-out Weekly Dashboard</h1>
    <p class="text-sm text-slate-400 mt-1">LG Electronics — IR Channel</p>
  </div>
  <div class="text-right text-xs text-slate-400">
    <div>Updated: 2026-03-30 16:46</div>
    <div>Data: W1~W13 2026</div>
  </div>
</div>
</header>

<!-- Tabs -->
<div class="sticky top-0 z-30 bg-slate-900/95 backdrop-blur border-b border-slate-700">
<div class="max-w-[1600px] mx-auto px-6">
<nav class="flex gap-1 pt-2" id="tabs">
  <button class="tab-btn active" data-tab="overview">Overview</button>
  <button class="tab-btn" data-tab="trend">Weekly Trend</button>
  <button class="tab-btn" data-tab="ranking">Model Ranking</button>
</nav>
</div>
</div>

<main class="max-w-[1600px] mx-auto px-6 py-6">

<!-- ===================== TAB 1: OVERVIEW ===================== -->
<section id="tab-overview">
  <div class="flex flex-wrap gap-3 mb-4 items-center">
    <div class="ms-wrap" id="ow_wrap">
      <button class="ms-btn" id="ow_btn">Week ▾</button>
      <div class="ms-menu" id="ow_menu">
        <div class="ms-actions"><button onclick="msAll('ow')">All</button><button class="ms-none" onclick="msNone('ow')">None</button></div>
        <div class="ms-list" id="ow_list"></div>
      </div>
    </div>
    <div class="ms-wrap" id="oc_wrap">
      <button class="ms-btn" id="oc_btn">Category ▾</button>
      <div class="ms-menu" id="oc_menu">
        <div class="ms-actions"><button onclick="msAll('oc')">All</button><button class="ms-none" onclick="msNone('oc')">None</button></div>
        <div class="ms-list" id="oc_list"></div>
      </div>
    </div>
    <button onclick="downloadExcel()" style="padding:4px 12px;border:1px solid #10b981;border-radius:4px;font-size:11px;cursor:pointer;background:#065f46;color:#d1fae5;font-weight:600;margin-left:8px">📥 Excel</button>
    <span class="text-xs text-slate-500" id="ov_filter_info"></span>
  </div>

  <div class="grid grid-cols-2 lg:grid-cols-5 gap-4 mb-6">
    <div class="kpi-card">
      <div class="kpi-label">Latest Week (W13)</div>
      <div class="kpi-val" id="kpi-lq">30</div>
      <div class="kpi-change dn">-34.8% WoW</div>
    </div>
    <div class="kpi-card">
      <div class="kpi-label">Current Month</div>
      <div class="kpi-val">165</div>
      <div class="kpi-change up">-10.3% MoM</div>
    </div>
    <div class="kpi-card">
      <div class="kpi-label">YTD Total</div>
      <div class="kpi-val">518</div>
    </div>
    <div class="kpi-card">
      <div class="kpi-label">Avg / Week</div>
      <div class="kpi-val">39.8</div>
    </div>
    <div class="kpi-card">
      <div class="kpi-label">Models / Categories</div>
      <div class="kpi-val">18<span class="text-base text-slate-400"> / 3</span></div>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 mb-4">
    <div class="card">
      <h3 class="text-sm font-semibold text-slate-300 mb-3">Weekly Sales Trend</h3>
      <div style="height:320px"><canvas id="c_weekly"></canvas></div>
    </div>
    <div class="card">
      <h3 class="text-sm font-semibold text-slate-300 mb-3">Monthly Sales</h3>
      <div style="height:320px"><canvas id="c_monthly"></canvas></div>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
    <div class="card">
      <h3 class="text-sm font-semibold text-slate-300 mb-3">Sales by Category</h3>
      <div style="height:320px"><canvas id="c_cat_pie"></canvas></div>
    </div>
    <div class="card">
      <h3 class="text-sm font-semibold text-slate-300 mb-3">Category Weekly Trend</h3>
      <div style="height:320px"><canvas id="c_cat_trend"></canvas></div>
    </div>
  </div>
</section>

<!-- ===================== TAB 2: WEEKLY TREND ===================== -->
<section id="tab-trend" style="display:none">
  <div class="flex flex-wrap gap-3 mb-4 items-center">
    <div class="ms-wrap" id="fw_wrap">
      <button class="ms-btn" id="fw_btn">Week ▾</button>
      <div class="ms-menu" id="fw_menu">
        <div class="ms-actions"><button onclick="msAll('fw')">All</button><button class="ms-none" onclick="msNone('fw')">None</button></div>
        <div class="ms-list" id="fw_list"></div>
      </div>
    </div>
    <div class="ms-wrap" id="fc_wrap">
      <button class="ms-btn" id="fc_btn">Category ▾</button>
      <div class="ms-menu" id="fc_menu">
        <div class="ms-actions"><button onclick="msAll('fc')">All</button><button class="ms-none" onclick="msNone('fc')">None</button></div>
        <div class="ms-list" id="fc_list"></div>
      </div>
    </div>
    <span class="text-xs text-slate-500" id="filter_info"></span>
  </div>

  <div class="card mb-4">
    <h3 class="text-sm font-semibold text-slate-300 mb-3">Model Weekly Trend (Top 10)</h3>
    <div style="height:400px"><canvas id="c_model_trend"></canvas></div>
  </div>

  <div class="card">
    <h3 class="text-sm font-semibold text-slate-300 mb-3">Model × Week Matrix</h3>
    <div class="tbl-wrap" id="matrix_tbl"></div>
  </div>
</section>

<!-- ===================== TAB 3: MODEL RANKING ===================== -->
<section id="tab-ranking" style="display:none">
  <div class="flex flex-wrap gap-3 mb-4 items-center">
    <div class="ms-wrap" id="rw_wrap">
      <button class="ms-btn" id="rw_btn">Week ▾</button>
      <div class="ms-menu" id="rw_menu">
        <div class="ms-actions"><button onclick="msAll('rw')">All</button><button class="ms-none" onclick="msNone('rw')">None</button></div>
        <div class="ms-list" id="rw_list"></div>
      </div>
    </div>
    <div class="ms-wrap" id="rc_wrap">
      <button class="ms-btn" id="rc_btn">Category ▾</button>
      <div class="ms-menu" id="rc_menu">
        <div class="ms-actions"><button onclick="msAll('rc')">All</button><button class="ms-none" onclick="msNone('rc')">None</button></div>
        <div class="ms-list" id="rc_list"></div>
      </div>
    </div>
    <input type="text" class="ms-btn" id="rank_search" placeholder="Search model..." style="width:180px"/>
  </div>

  <div class="card">
    <h3 class="text-sm font-semibold text-slate-300 mb-3">Model Ranking</h3>
    <div class="tbl-wrap" id="rank_tbl"></div>
  </div>
</section>

</main>

<footer class="text-center text-xs text-slate-600 py-4 border-t border-slate-800">
  Tamkeen Sell-out Dashboard · Generated 2026-03-30 16:46 · Powered by 소놀봇
</footer>

