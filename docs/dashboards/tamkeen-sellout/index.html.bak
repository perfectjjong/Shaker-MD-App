},{"s":"LC242C","n":"LG Split Jet Cool 24 Cold (New)","b":"LG","c":"Split AC","t":1,"wk":{"W13":1}}],"weekly":{"W1":38,"W10":45,"W11":44,"W12":46,"W13":30,"W2":66,"W3":21,"W4":26,"W5":18,"W6":18,"W7":62,"W8":62,"W9":42},"monthly":{"Jan":169,"Mar":165,"Feb":184}};

// ===== TAB SWITCHING =====
document.querySelectorAll('.tab-btn').forEach(btn=>{
  btn.addEventListener('click',()=>{
    document.querySelectorAll('.tab-btn').forEach(b=>b.classList.remove('active'));
    btn.classList.add('active');
    document.querySelectorAll('main>section').forEach(s=>s.style.display='none');
    document.getElementById('tab-'+btn.dataset.tab).style.display='';
    if(btn.dataset.tab==='trend')renderTrend();
    if(btn.dataset.tab==='ranking')renderRanking();
  });
});

// ===== CHART COLORS =====
const COLORS=['#10b981','#f59e0b','#3b82f6','#8b5cf6','#f43f5e','#14b8a6','#0ea5e9','#6366f1','#ec4899','#84cc16'];
const CAT_COLORS={'Split AC':'#3b82f6','Window AC':'#f59e0b','Floor Standing AC':'#10b981','Concealed':'#a855f7','Cassette':'#22d3ee'};

// ===== MULTI-SELECT FILTER =====
const FILTERS={};
function initMS(id,items,onChange){
  FILTERS[id]={selected:new Set(items),items,onChange};
  const list=document.getElementById(id+'_list');
  items.forEach(it=>{
    const lbl=document.createElement('label');
    lbl.innerHTML=`<input type="checkbox" checked value="${it}"/> <span>${it}</span>`;
    lbl.querySelector('input').addEventListener('change',e=>{
      if(e.target.checked)FILTERS[id].selected.add(it);else FILTERS[id].selected.delete(it);
      onChange();
    });
    list.appendChild(lbl);
  });
  document.getElementById(id+'_btn').addEventListener('click',e=>{
    e.stopPropagation();
    document.getElementById(id+'_menu').classList.toggle('open');
  });
}
function msAll(id){FILTERS[id].items.forEach(i=>FILTERS[id].selected.add(i));document.querySelectorAll('#'+id+'_list input').forEach(i=>i.checked=true);FILTERS[id].onChange();}
function msNone(id){FILTERS[id].selected.clear();document.querySelectorAll('#'+id+'_list input').forEach(i=>i.checked=false);FILTERS[id].onChange();}
document.addEventListener('click',()=>document.querySelectorAll('.ms-menu.open').forEach(m=>m.classList.remove('open')));
document.querySelectorAll('.ms-wrap').forEach(w=>w.addEventListener('click',e=>e.stopPropagation()));

// ===== UTILITY =====
const fmt=n=>n==null?'-':n.toLocaleString();
function catBadge(c){
  const cls=c.includes('Split')?'cat-split':c.includes('Window')?'cat-window':c.includes('Concealed')?'cat-concealed':c.includes('Cassette')?'cat-cassette':c.includes('Floor')?'cat-floor':'cat-floor';
  return `<span class="cat-badge ${cls}">${c}</span>`;
}">${c}</span>`;
}
function destroyChart(id){
  const c=Chart.getChart(id);
  if(c)c.destroy();
}

// ===== TAB 1: OVERVIEW =====
let ovInit=false;
function renderOverview(){
  if(!ovInit){
    initMS('ow',D.meta.weeks,renderOverview);
    initMS('oc',D.dims.categories,renderOverview);
    ovInit=true;
  }
  const selW=FILTERS.ow.selected;
  const selC=FILTERS.oc.selected;
  const filt=D.raw.filter(r=>selW.has(r.w)&&selC.has(r.c));
  const weeks=D.meta.weeks.filter(w=>selW.has(w));

  const filtTotal=filt.reduce((s,r)=>s+r.q,0);
  document.getElementById('ov_filter_info').textContent=`${filt.length} rows · ${filtTotal.toLocaleString()} units`;

  const weeklyF={};
  filt.forEach(r=>{weeklyF[r.w]=(weeklyF[r.w]||0)+r.q});
  destroyChart('c_weekly');
  new Chart(document.getElementById('c_weekly'),{
    type:'bar',
    data:{
      labels:weeks.map(w=>w+'\n'+(D.meta.week_dates[w]||'')),
      datasets:[{label:'Qty',data:weeks.map(w=>weeklyF[w]||0),backgroundColor:'#10b981',borderRadius:6}]
    },
    options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false},datalabels:{anchor:'end',align:'top',color:'#94a3b8',font:{size:10,weight:600},formatter:v=>v>0?v:''}},scales:{x:{ticks:{color:'#94a3b8',font:{size:9}},grid:{display:false}},y:{ticks:{color:'#64748b'},grid:{color:'#1e293b'}}}}
  });

  const monthlyF={};
  filt.forEach(r=>{monthlyF[r.m]=(monthlyF[r.m]||0)+r.q});
  const months=D.meta.months.filter(m=>Object.keys(monthlyF).includes(m));
  destroyChart('c_monthly');
  new Chart(document.getElementById('c_monthly'),{
    type:'bar',
    data:{
      labels:months,
      datasets:[{label:'Qty',data:months.map(m=>monthlyF[m]||0),backgroundColor:'#8b5cf6',borderRadius:6}]
    },
    options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false},datalabels:{anchor:'end',align:'top',color:'#94a3b8',font:{size:11,weight:600},formatter:v=>v>0?v:''}},scales:{x:{ticks:{color:'#94a3b8'},grid:{display:false}},y:{ticks:{color:'#64748b'},grid:{color:'#1e293b'}}}}
  });

  destroyChart('c_cat_pie');
  const catTotals={};
  filt.forEach(r=>{catTotals[r.c]=(catTotals[r.c]||0)+r.q});
  const cats=Object.keys(catTotals).sort();
  new Chart(document.getElementById('c_cat_pie'),{
    type:'doughnut',
    data:{
      labels:cats,
      datasets:[{data:cats.map(c=>catTotals[c]),backgroundColor:cats.map(c=>CAT_COLORS[c]||'#64748b')}]
    },
    options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{position:'bottom',labels:{color:'#e2e8f0',padding:15}},datalabels:{color:'#fff',font:{weight:700,size:12},formatter:(v,ctx)=>{const t=ctx.dataset.data.reduce((a,b)=>a+b,0);return t?Math.round(v/t*100)+'%':''}}}}
  });

  destroyChart('c_cat_trend');
  const catWeekly={};
  filt.forEach(r=>{
    if(!catWeekly[r.c])catWeekly[r.c]={};
    catWeekly[r.c][r.w]=(catWeekly[r.c][r.w]||0)+r.q;
  });
  new Chart(document.getElementById('c_cat_trend'),{
    type:'bar',
    data:{
      labels:weeks,
      datasets:cats.map(c=>({label:c,data:weeks.map(w=>catWeekly[c]?.[w]||0),backgroundColor:CAT_COLORS[c]||'#64748b'}))
    },
    options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{position:'top',labels:{color:'#e2e8f0',boxWidth:12}},datalabels:{display:false}},scales:{x:{stacked:true,ticks:{color:'#94a3b8'},grid:{display:false}},y:{stacked:true,ticks:{color:'#64748b'},grid:{color:'#1e293b'}}}}
  });
}

// ===== TAB 2: WEEKLY TREND =====
let trendInit=false;
function renderTrend(){
  if(!trendInit){
    initMS('fw',D.meta.weeks,renderTrend);
    initMS('fc',D.dims.categories,renderTrend);
    trendInit=true;
  }
  const selW=FILTERS.fw.selected;
  const selC=FILTERS.fc.selected;
  const filt=D.raw.filter(r=>selW.has(r.w)&&selC.has(r.c));
  const weeks=[...selW].sort((a,b)=>parseInt(a.slice(1))-parseInt(b.slice(1)));

  document.getElementById('filter_info').textContent=`${filt.length} rows · ${filt.reduce((s,r)=>s+r.q,0).toLocaleString()} units`;

  const mq={};
  filt.forEach(r=>{mq[r.s]=(mq[r.s]||0)+r.q});
  const top10=Object.entries(mq).sort((a,b)=>b[1]-a[1]).slice(0,10).map(e=>e[0]);

  destroyChart('c_model_trend');
  const datasets=top10.map((sku,i)=>{
    const md=D.models.find(m=>m.s===sku);
    const label=md?md.n.substring(0,30):sku;
    return {label,data:weeks.map(w=>{const fr=filt.filter(r=>r.s===sku&&r.w===w);return fr.reduce((s,r)=>s+r.q,0)}),borderColor:COLORS[i%COLORS.length],backgroundColor:COLORS[i%COLORS.length]+'30',tension:.3,fill:false,pointRadius:4};
  });
  new Chart(document.getElementById('c_model_trend'),{
    type:'line',
    data:{labels:weeks,datasets},
    options:{responsive:true,maintainAspectRatio:false,interaction:{mode:'index',intersect:false},plugins:{legend:{position:'bottom',labels:{color:'#e2e8f0',boxWidth:12,font:{size:10}}},datalabels:{display:false}},scales:{x:{ticks:{color:'#94a3b8'},grid:{display:false}},y:{ticks:{color:'#64748b'},grid:{color:'#1e293b'}}}}
  });

  const allSKUs=[...new Set(filt.map(r=>r.s))];
  const skuQty={};
  filt.forEach(r=>{skuQty[r.s]=(skuQty[r.s]||0)+r.q});
  const sorted=allSKUs.sort((a,b)=>(skuQty[b]||0)-(skuQty[a]||0));

  let h='<table><thead><tr><th>#</th><th>Model</th><th>Category</th>';
  weeks.forEach(w=>h+=`<th>${w}</th>`);
  h+='<th>Total</th></tr></thead><tbody>';
  sorted.forEach((sku,i)=>{
    const md=D.models.find(m=>m.s===sku);
    const name=md?md.n.substring(0,35):sku;
    const cat=md?md.c:'';
    h+=`<tr><td>${i+1}</td><td title="${md?md.n:sku}">${name}</td><td>${catBadge(cat)}</td>`;
    let total=0;
    weeks.forEach(w=>{
      const q=filt.filter(r=>r.s===sku&&r.w===w).reduce((s,r)=>s+r.q,0);
      total+=q;
      h+=`<td style="text-align:right">${q||'-'}</td>`;
    });
    h+=`<td style="text-align:right;font-weight:700">${total}</td></tr>`;
  });
  h+='</tbody></table>';
  document.getElementById('matrix_tbl').innerHTML=h;
}

// ===== TAB 3: RANKING =====
let rankInit=false;
function renderRanking(){
  if(!rankInit){
    initMS('rw',D.meta.weeks,renderRanking);
    initMS('rc',D.dims.categories,renderRanking);
    document.getElementById('rank_search').addEventListener('input',renderRanking);
    rankInit=true;
  }
  const selW=FILTERS.rw.selected;
  const selC=FILTERS.rc.selected;
  const q=document.getElementById('rank_search').value.toLowerCase();
  const filt=D.raw.filter(r=>selW.has(r.w)&&selC.has(r.c));

  const agg={};
  filt.forEach(r=>{
    if(!agg[r.s])agg[r.s]={s:r.s,n:r.n,b:r.b,c:r.c,q:0};
    agg[r.s].q+=r.q;
  });
  let list=Object.values(agg).sort((a,b)=>b.q-a.q);
  if(q)list=list.filter(m=>m.n.toLowerCase().includes(q)||m.s.toLowerCase().includes(q));
  const maxQ=list.length?list[0].q:1;
  const total=list.reduce((s,m)=>s+m.q,0);

  let h='<table><thead><tr><th>#</th><th>SKU</th><th>Model</th><th>Category</th><th style="text-align:right">Qty</th><th style="text-align:right">Share</th><th style="width:200px">Progress</th></tr></thead><tbody>';
  list.forEach((m,i)=>{
    const pct=total?Math.round(m.q/total*100):0;
    const barW=maxQ?Math.round(m.q/maxQ*100):0;
    h+=`<tr><td>${i+1}</td><td style="font-family:monospace;font-size:11px">${m.s}</td><td>${m.n}</td><td>${catBadge(m.c)}</td><td style="text-align:right;font-weight:600">${fmt(m.q)}</td><td style="text-align:right">${pct}%</td><td><div class="progress-bar"><div class="progress-fill" style="width:${barW}%"></div></div></td></tr>`;
  });
  h+='</tbody></table>';
  document.getElementById('rank_tbl').innerHTML=h;
}

// ===== INIT =====
Chart.register(ChartDataLabels);
Chart.defaults.color='#94a3b8';
Chart.defaults.font.family='Inter';
renderOverview();
</script>
</body></html>