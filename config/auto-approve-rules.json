{
  "enabled": false,
  "rules": [
    {
      "name": "Read-only 명령어",
      "pattern": "^(ls|cat|head|tail|wc|file|stat|which|echo|pwd|whoami|date|git\\s+(status|log|diff|branch|show))\\b",
      "action": "approve",
      "active": true
    },
    {
      "name": "npm/yarn 읽기 명령어",
      "pattern": "^(npm\\s+(list|ls|outdated|audit)|yarn\\s+(list|info|why))\\b",
      "action": "approve",
      "active": true
    },
    {
      "name": "위험 명령어 차단",
      "pattern": "(rm\\s+-rf\\s+/|sudo\\s+rm|mkfs|dd\\s+if|:(){ :|&};:)",
      "action": "reject",
      "active": true
    },
    {
      "name": "파일 편집 도구 허용",
      "pattern": null,
      "tool": "Edit",
      "action": "approve",
      "active": false
    },
    {
      "name": "파일 쓰기 도구 허용",
      "pattern": null,
      "tool": "Write",
      "action": "approve",
      "active": false
    }
  ]
}